        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "wifi_name": { "type": "string" },
                "wifi_password": { "type": "string" }
              }
            }
          }
        }
      },
      {
        "name": "issue_invoice",
