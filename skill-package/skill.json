          }
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "address": { "type": "string" },
                "phone": { "type": "string" },
                "hours": { "type": "object" },
                "location": { "type": "object" }
              }
            }
          }
