        "name": "get_coupons",
        "display_name": "获取优惠券",
        "description": "获取用户可用的优惠券列表。使用场景：用户说'看看优惠券'、'有什么优惠券可以用'时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
