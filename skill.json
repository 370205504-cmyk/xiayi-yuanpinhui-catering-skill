{
  "name": "xiayi-yuanpinhui-catering-skill",
  "version": "4.0.0",
  "description": "夏邑缘品荟智能餐饮服务系统 - MCP标准Agent Skill，支持语音点餐、AI Agent接入、多门店管理、多租户隔离、状态机控制、RBAC权限",
  "author": "石中伟",
  "license": "MIT",
  "keywords": [
    "restaurant",
    "ordering",
    "ai-agent",
    "mcp",
    "multi-tenant",
    "state-machine",
    "rbac"
  ],
  "mcp": {
    "protocol_version": "2024-11-05",
    "endpoint": "https://mcp.xiayi-yuanpinhui.com",
    "transport": "http",
    "authentication": {
      "type": "bearer",
      "header": "Authorization",
      "tenant_header": "X-Tenant-Id",
      "api_key_header": "X-API-Key"
    },
    "error_codes": {
      "1001": "参数错误或缺少必要参数",
      "1002": "业务逻辑错误",
      "1003": "权限不足",
      "1004": "资源不存在",
      "1005": "需要修改密码",
      "1006": "请求过于频繁",
      "1007": "签名验证失败",
      "1008": "请求包含非法字符",
      "1009": "幂等键无效或已使用",
      "1010": "CSRF验证失败",
      "2001": "订单不存在",
      "2002": "菜品不存在",
      "2003": "库存不足",
      "2004": "订单状态不允许此操作",
      "2005": "订单已支付",
      "3001": "排队不存在",
      "3002": "排队已取消",
      "3003": "排队已叫号",
      "4001": "租户不存在或已禁用",
      "4002": "API Key无效或已过期",
      "5001": "支付失败",
      "5002": "退款失败"
    },
    "tools": [
      {
        "name": "get_menu",
        "description": "获取完整菜单或指定分类的菜品列表。使用场景：用户想浏览菜单或查看某个分类的菜品时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "category": {
              "type": "string",
              "description": "菜品分类",
              "enum": ["招牌菜", "特色硬菜", "宴请首选", "餐前开胃", "家常炒菜", "汤羹主食", "全部"]
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID（多租户场景必填）"
            }
          }
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "categories": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "dishes": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": { "type": "string" },
                            "name": { "type": "string" },
                            "price": { "type": "number" },
                            "description": { "type": "string" },
                            "spicy_level": { "type": "number" },
                            "is_available": { "type": "boolean" },
                            "stock": { "type": "number" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "examples": [
          {"category": "招牌菜"},
          {"category": "全部"}
        ]
      },
      {
        "name": "get_dish_detail",
        "description": "获取指定菜品的详细信息，包括价格、描述、辣度、库存等。使用场景：用户想了解某道菜的具体信息时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "dish_id": {
              "type": "string",
              "description": "菜品ID",
              "pattern": "^[0-9]+$"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["dish_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "name_en": { "type": "string" },
                "price": { "type": "number" },
                "description": { "type": "string" },
                "spicy_level": { "type": "number", "description": "0不辣,1微辣,2中辣,3特辣" },
                "stock": { "type": "number" },
                "is_available": { "type": "boolean" },
                "image_url": { "type": "string" },
                "allergens": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      },
      {
        "name": "recommend_dishes",
        "description": "根据用户偏好智能推荐菜品。使用场景：用户不知道吃什么或想要个性化推荐时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "preferences": {
              "type": "object",
              "properties": {
                "spicy_level": {
                  "type": "number",
                  "description": "辣度偏好：0不辣、1微辣、2中辣、3特辣",
                  "minimum": 0,
                  "maximum": 3
                },
                "price_range": {
                  "type": "string",
                  "description": "价格区间",
                  "enum": ["low", "medium", "high", "all"]
                },
                "people_count": {
                  "type": "number",
                  "description": "用餐人数",
                  "minimum": 1,
                  "maximum": 20
                },
                "exclude": {
                  "type": "array",
                  "description": "排除的菜品ID列表",
                  "items": { "type": "string" }
                }
              }
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "recommendations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "dish": { "type": "object" },
                      "reason": { "type": "string", "description": "推荐理由" },
                      "score": { "type": "number", "description": "推荐分数0-100" }
                    }
                  }
                },
                "total_price": { "type": "number", "description": "预估总价" }
              }
            }
          }
        }
      },
      {
        "name": "add_to_cart",
        "description": "添加菜品到购物车。使用场景：用户要点菜时调用，支持指定数量和备注。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID",
              "pattern": "^[a-zA-Z0-9_-]+$"
            },
            "dish_id": {
              "type": "string",
              "description": "菜品ID",
              "pattern": "^[0-9]+$"
            },
            "quantity": {
              "type": "number",
              "description": "数量",
              "minimum": 1,
              "maximum": 10,
              "default": 1
            },
            "remarks": {
              "type": "string",
              "description": "备注，如'少辣'、'不要葱'、'打包'",
              "maxLength": 50
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id", "dish_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "code": { "type": "number" },
            "message": { "type": "string" },
            "data": {
              "type": "object",
              "properties": {
                "cart_item_id": { "type": "string" },
                "dish_name": { "type": "string" },
                "quantity": { "type": "number" },
                "subtotal": { "type": "number" },
                "cart_total": { "type": "number" },
                "cart_items_count": { "type": "number" }
              }
            }
          }
        },
        "errors": [
          {"code": 2002, "message": "菜品不存在"},
          {"code": 2003, "message": "库存不足"}
        ],
        "examples": [
          {"user_id": "user_001", "dish_id": "1", "quantity": 1, "remarks": "少辣"},
          {"user_id": "user_001", "dish_id": "2", "quantity": 2}
        ]
      },
      {
        "name": "remove_from_cart",
        "description": "从购物车移除菜品。使用场景：用户想取消已点的菜时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "dish_id": {
              "type": "string",
              "description": "菜品ID"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id", "dish_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "removed_item": { "type": "string" },
                "cart_total": { "type": "number" }
              }
            }
          }
        }
      },
      {
        "name": "get_cart",
        "description": "获取用户购物车内容。使用场景：用户想查看已点的菜品时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "dish_id": { "type": "string" },
                      "dish_name": { "type": "string" },
                      "quantity": { "type": "number" },
                      "unit_price": { "type": "number" },
                      "subtotal": { "type": "number" },
                      "remarks": { "type": "string" }
                    }
                  }
                },
                "total": { "type": "number" },
                "items_count": { "type": "number" }
              }
            }
          }
        }
      },
      {
        "name": "clear_cart",
        "description": "清空用户购物车。使用场景：用户想重新点菜时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "message": { "type": "string" }
          }
        }
      },
      {
        "name": "create_order",
        "description": "提交订单。使用场景：用户确认点菜后调用，会扣减库存并生成订单。支持幂等性，传入request_id可防止重复下单。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "order_type": {
              "type": "string",
              "description": "订单类型",
              "enum": ["dine_in", "takeout", "delivery"]
            },
            "table_no": {
              "type": "string",
              "description": "桌号（堂食时必填）",
              "maxLength": 20
            },
            "remarks": {
              "type": "string",
              "description": "订单备注",
              "maxLength": 200
            },
            "address": {
              "type": "string",
              "description": "送餐地址（外卖时必填）",
              "maxLength": 200
            },
            "contact_phone": {
              "type": "string",
              "description": "联系电话",
              "pattern": "^1[3-9]\\d{9}$"
            },
            "request_id": {
              "type": "string",
              "description": "幂等键，客户端生成的唯一标识，防止重复下单",
              "pattern": "^[a-f0-9]{32,64}$"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id", "order_type"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "code": { "type": "number" },
            "message": { "type": "string" },
            "data": {
              "type": "object",
              "properties": {
                "order_no": { "type": "string" },
                "total_amount": { "type": "number" },
                "final_amount": { "type": "number" },
                "discount_amount": { "type": "number" },
                "points_earned": { "type": "number" },
                "status": { "type": "string" },
                "pay_expire_at": { "type": "string" },
                "idempotent": { "type": "boolean", "description": "是否幂等返回" }
              }
            }
          }
        },
        "errors": [
          {"code": 1001, "message": "购物车为空"},
          {"code": 2003, "message": "库存不足"},
          {"code": 1009, "message": "重复请求"}
        ]
      },
      {
        "name": "get_orders",
        "description": "获取用户订单列表。使用场景：用户想查看自己的历史订单时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "status": {
              "type": "string",
              "description": "订单状态筛选",
              "enum": ["pending", "confirmed", "preparing", "ready", "completed", "cancelled", "all"]
            },
            "page": {
              "type": "number",
              "description": "页码",
              "minimum": 1,
              "default": 1
            },
            "limit": {
              "type": "number",
              "description": "每页数量",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "orders": { "type": "array" },
                "total": { "type": "number" },
                "page": { "type": "number" },
                "limit": { "type": "number" }
              }
            }
          }
        }
      },
      {
        "name": "get_order_detail",
        "description": "获取订单详情。使用场景：用户想查看某个订单的详细信息时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "order_no": {
              "type": "string",
              "description": "订单号",
              "pattern": "^ORD[0-9]+$"
            },
            "user_id": {
              "type": "string",
              "description": "用户ID（用于权限校验）"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["order_no"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "order_no": { "type": "string" },
                "status": { "type": "string" },
                "payment_status": { "type": "string" },
                "total_amount": { "type": "number" },
                "final_amount": { "type": "number" },
                "items": { "type": "array" },
                "created_at": { "type": "string" },
                "status_history": { "type": "array" }
              }
            }
          }
        },
        "errors": [
          {"code": 2001, "message": "订单不存在"},
          {"code": 1003, "message": "无权查看该订单"}
        ]
      },
      {
        "name": "cancel_order",
        "description": "取消订单。使用场景：用户想取消订单时调用，仅在待确认或已接单状态时可取消。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "order_no": {
              "type": "string",
              "description": "订单号"
            },
            "reason": {
              "type": "string",
              "description": "取消原因",
              "maxLength": 100
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["user_id", "order_no"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "code": { "type": "number" },
            "message": { "type": "string" },
            "data": {
              "type": "object",
              "properties": {
                "order_no": { "type": "string" },
                "status": { "type": "string" },
                "refund_amount": { "type": "number", "description": "退款金额（如已支付）" }
              }
            }
          }
        },
        "errors": [
          {"code": 2001, "message": "订单不存在"},
          {"code": 2004, "message": "订单状态不允许取消"},
          {"code": 1003, "message": "无权操作该订单"}
        ]
      },
      {
        "name": "queue_take",
        "description": "排队取号。使用场景：用户到店需要排队等位时调用。支持幂等性。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "store_id": {
              "type": "string",
              "description": "门店ID"
            },
            "table_type": {
              "type": "string",
              "description": "桌型",
              "enum": ["small", "medium", "large", "room"]
            },
            "people": {
              "type": "number",
              "description": "用餐人数",
              "minimum": 1,
              "maximum": 20
            },
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "phone": {
              "type": "string",
              "description": "联系电话",
              "pattern": "^1[3-9]\\d{9}$"
            },
            "request_id": {
              "type": "string",
              "description": "幂等键"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["store_id", "table_type", "people"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "queue_id": { "type": "string" },
                "queue_no": { "type": "string", "description": "排队号，如A025" },
                "table_type": { "type": "string" },
                "wait_count": { "type": "number", "description": "前方等待人数" },
                "estimated_time": { "type": "number", "description": "预计等待分钟" }
              }
            }
          }
        }
      },
      {
        "name": "query_queue",
        "description": "查询排队进度。使用场景：用户想查看排队进度时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "queue_id": {
              "type": "string",
              "description": "排队ID"
            },
            "user_id": {
              "type": "string",
              "description": "用户ID（用于权限校验）"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["queue_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
                "queue_id": { "type": "string" },
                "queue_no": { "type": "string" },
                "status": { "type": "string" },
                "wait_count": { "type": "number" },
                "estimated_time": { "type": "number" }
              }
            }
          }
        },
        "errors": [
          {"code": 3001, "message": "排队不存在"},
          {"code": 3002, "message": "排队已取消"}
        ]
      },
      {
        "name": "cancel_queue",
        "description": "取消排队。使用场景：用户不想等了要取消排队时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "queue_id": {
              "type": "string",
              "description": "排队ID"
            },
            "user_id": {
              "type": "string",
              "description": "用户ID"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          },
          "required": ["queue_id"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "message": { "type": "string" }
          }
        },
        "errors": [
          {"code": 3001, "message": "排队不存在"},
          {"code": 3003, "message": "排队已叫号，无法取消"}
        ]
      },
      {
        "name": "get_store_info",
        "description": "获取门店信息，包括营业时间、地址、联系方式等。使用场景：用户想了解门店信息时调用。",
        "inputSchema": {
          "type": "object",
          "properties": {
            "store_id": {
              "type": "string",
              "description": "门店ID，不填则返回默认门店"
            },
            "tenant_id": {
              "type": "string",
              "description": "租户ID"
            }
          }
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "data": {
              "type": "object",
              "properties": {
