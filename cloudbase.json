{
  "version": "2.0",
  "envId": "xiayi-yuanpinhui",
  "functionRoot": "./lambda",
  "functions": [
    {
      "name": "xiayi-catering-skill",
      "timeout": 30,
      "memorySize": 512,
      "runtime": "Nodejs16.13",
      "handler": "server.handler",
      "environment": {
        "variables": {
          "NODE_ENV": "production",
          "PORT": "80"
        }
      },
      "vpc": {
        "vpcId": "",
        "subnetId": ""
      }
    }
  ],
  "triggerNamespace": {
    "triggers": [
      {
        "name": "api-trigger",
        "type": "apigw",
        "config": {
          "methods": ["ANY"],
          "path": "/api/v1",
          "serviceName": "xiayi-yuanpinhui-api",
          "apiName": "xiayi-catering-api"
        }
      }
    ]
  }
}
