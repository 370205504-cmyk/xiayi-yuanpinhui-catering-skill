  "author": "石中伟",
  "license": "MIT",
  "dependencies": {
    "axios": "1.6.2",
    "bcryptjs": "2.4.3",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "7.0.1",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.6.5",
    "node-cron": "3.0.3",
