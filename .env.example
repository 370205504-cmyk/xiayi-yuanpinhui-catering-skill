# 夏邑缘品荟智能餐饮系统 - 环境变量配置示例
# ⚠️ 生产环境请务必修改所有密钥和密码

PORT=3000
NODE_ENV=production

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=xiayi_app
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=xiayi_restaurant
DB_CONNECTION_LIMIT=20
DB_CONNECT_TIMEOUT=10000

# ==================== Redis配置 ====================
# ⚠️ 生产环境必须设置密码
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_TO_A_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_KEY_PREFIX=xiayi:
REDIS_CACHE_TTL=3600

# ==================== JWT认证配置 ====================
# ⚠️ 生产环境请使用至少64位随机字符串
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_AND_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_VERY_LONG_AND_RANDOM_REFRESH_SECRET_KEY
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ==================== 微信支付配置 ====================
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_APIKEY=your_wechat_apikey
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_CERT_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/callback
WECHAT_CERT_EXPIRY=2027-01-01

# ==================== 支付宝配置 ====================
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/callback
ALIPAY_SIGN_TYPE=RSA2

# ==================== 打印机配置 ====================
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
PRINTER_ENABLED=true
PRINTER_TIMEOUT=5000

# ==================== 安全配置 ====================
# CORS白名单（多个用逗号分隔）
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# API限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_ORDER_WINDOW_MS=60000
RATE_LIMIT_ORDER_MAX=10

# IP黑名单（多个用逗号分隔）
BLOCKED_IPS=

# 会话配置
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_VERY_LONG_SESSION_SECRET
SESSION_MAX_AGE=86400000

# 加密密钥（用于敏感数据加密）
ENCRYPTION_KEY=CHANGE_THIS_TO_A_32_CHAR_ENCRYPTION_KEY_HERE

# ==================== 管理员配置 ====================
# 管理员用户ID列表（多个用逗号分隔）
ADMIN_USER_IDS=1
ADMIN_API_KEY=CHANGE_THIS_TO_A_VERY_LONG_AND_SECURE_ADMIN_API_KEY

# ==================== 日志与监控 ====================
LOG_LEVEL=info
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# 告警配置
ALERT_EMAIL=admin@your-domain.com
ALERT_WEBHOOK_URL=

# ==================== 备份配置 ====================
BACKUP_PATH=/workspace/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 3 * * *

# ==================== 存储配置 ====================
UPLOAD_PATH=/workspace/uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==================== 其他配置 ====================
LOCALE=zh_CN
TIMEZONE=Asia/Shanghai
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
