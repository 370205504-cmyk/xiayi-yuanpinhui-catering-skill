# 夏邑缘品荟智能餐饮系统 - 环境变量配置示例
# 
# ⚠️ 重要警告 ⚠️
# 1. 此文件仅为配置示例，生产环境请复制为 .env 文件并修改配置
# 2. .env 文件已加入 .gitignore，绝对不要提交到 Git 仓库
# 3. 敏感信息（如密码、密钥）应使用云服务密钥管理服务（如腾讯云KMS）
# 4. 生产环境必须修改所有默认密码和密钥

# 服务配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# JWT配置 - 必须修改！
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE_32_CHARACTERS_MINIMUM
JWT_REFRESH_SECRET=YOUR_REFRESH_SECRET_KEY_HERE_32_CHARACTERS_MINIMUM
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 签名验证配置
SIGNING_SECRET=YOUR_SIGNING_SECRET_KEY_HERE

# 数据库配置 - 必须修改！
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DATABASE_PASSWORD
DB_NAME=xiayi_restaurant
DB_POOL_MIN=10
DB_POOL_MAX=50

# 读写分离配置（可选）
# DB_READ_HOST=slave.example.com
# DB_READ_PORT=3306

# Redis配置 - 必须修改！
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0

# 微信支付配置
WECHAT_APPID=YOUR_WECHAT_APPID
WECHAT_MCHID=YOUR_WECHAT_MCHID
WECHAT_APIKEY=YOUR_WECHAT_APIKEY
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/callback
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_CERT_SERIAL=YOUR_CERT_SERIAL_NUMBER

# 支付宝配置
ALIPAY_APPID=YOUR_ALIPAY_APPID
ALIPAY_PRIVATE_KEY=YOUR_ALIPAY_PRIVATE_KEY
ALIPAY_PUBLIC_KEY=YOUR_ALIPAY_PUBLIC_KEY
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/callback

# 管理员配置
ADMIN_USER_IDS=1,2

# 跨域配置
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 限流配置
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_ORDER=10

# 文件上传配置
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
BLOCKED_IPS=192.168.1.100,10.0.0.50