PORT=3000
NODE_ENV=development

# 数据库配置（建议创建专用用户）
# 创建命令：CREATE USER 'xiayi_app'@'localhost' IDENTIFIED BY 'your_password';
# 授权命令：GRANT SELECT, INSERT, UPDATE, DELETE ON xiayi_restaurant.* TO 'xiayi_app'@'localhost';
DB_HOST=localhost
DB_PORT=3306
DB_USER=xiayi_app
DB_PASSWORD=your_secure_password_here
DB_NAME=xiayi_restaurant
DB_CONNECTION_LIMIT=20

# Redis缓存
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT密钥（生产环境请务必修改）
JWT_SECRET=xiayi-yuanpinhui-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_APIKEY=your_wechat_apikey
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/callback

# 支付宝配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/callback

# 热敏打印机配置
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000

# 备份配置
BACKUP_PATH=/workspace/backups
BACKUP_RETENTION_DAYS=30

# 管理员配置
ADMIN_USER_IDS=1,2,3
ADMIN_PHONES=13800138000
ADMIN_API_KEY=your-secure-admin-api-key-at-least-32-chars
